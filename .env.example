# OKXTRENDBOT is intentionally separate from OKXStatBot.
# Keep credentials, DB, logs, and runtime state independent.

TREND_BOT_MODE=paper
TREND_BOT_SYMBOL=BTC-USDT-SWAP
TREND_BOT_TIMEFRAME=1H
TREND_BOT_DB_PATH=data/okxtrendbot.sqlite
TREND_BOT_LOG_PATH=logs/okxtrendbot.log

# Signal model
TREND_BOT_EMA_FAST=20
TREND_BOT_EMA_SLOW=60
TREND_BOT_ATR_PERIOD=14
TREND_BOT_BREAKOUT_LOOKBACK=20
TREND_BOT_MIN_EMA_GAP_ATR=0.20
TREND_BOT_MAX_EXTENSION_ATR=3.00
TREND_BOT_STOP_ATR_MULT=2.50

# Risk defaults are intentionally small for the first version.
TREND_BOT_RISK_PER_TRADE_PCT=0.25
TREND_BOT_MAX_NOTIONAL_USDT=100.00

